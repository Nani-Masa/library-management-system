# ============================================================
# LibraryOS — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL="postgresql://library_user:library_pass@localhost:5432/libraryos"

# Separate vars (used by docker-compose)
DB_USER="library_user"
DB_PASSWORD="library_pass"
DB_NAME="libraryos"

# ── Authentication ────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION"

# ── Email (optional — for due-date reminders) ─────────────────
# Create a Gmail App Password at:
#   https://myaccount.google.com/apppasswords  (requires 2FA enabled)
EMAIL_USER="your.library.email@gmail.com"
EMAIL_PASS="your-16-char-app-password"

# ── URLs ──────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ── Application ───────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
